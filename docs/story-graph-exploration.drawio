<?xml version='1.0' encoding='utf-8'?>
<mxfile host="app.diagrams.net"><diagram name="Story Map" id="story-map"><mxGraphModel><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="resolve-checks" value="Resolve Checks" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="120" width="810" height="60" as="geometry" /></mxCell><mxCell id="resolve-checks/make-a-check" value="Make A Check" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="25" y="195" width="420" height="60" as="geometry" /></mxCell><mxCell id="resolve-checks/make-a-check/make-trait-check" value="Make Trait Check" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="30" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/make-a-check/grade-check-result-by-degree" value="Grade Check Result by Degree" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="90" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/make-a-check/make-opposed-check-against-opponent" value="Make Opposed Check Against Opponent" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="150" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/make-a-check/resolve-comparison-check-without-roll" value="Resolve Comparison Check Without Roll" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="210" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/make-a-check/make-resistance-check-against-effect" value="Make Resistance Check Against Effect" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="270" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/make-a-check/perform-routine-check" value="Perform Routine Check" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="330" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/make-a-check/lead-team-check-with-helpers" value="Lead Team Check with Helpers" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="390" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/apply-conditions" value="Apply Conditions" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="455" y="195" width="120" height="60" as="geometry" /></mxCell><mxCell id="resolve-checks/apply-conditions/apply-condition-to-character" value="Apply Condition to Character" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="460" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/apply-conditions/supersede-condition-in-chain" value="Supersede Condition in Chain" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="520" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/recover-from-conditions" value="Recover from Conditions" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="585" y="195" width="240" height="60" as="geometry" /></mxCell><mxCell id="resolve-checks/recover-from-conditions/roll-resistance-check-against-ongoing-effect-to-remove-conditions" value="Roll Resistance Check Against Ongoing Effect to Remove Conditions" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="590" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/recover-from-conditions/remove-condition-when-source-effect-ends" value="Remove Condition When Source Effect Ends" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="650" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/recover-from-conditions/roll-fortitude-check-to-stabilize-while-dying" value="Roll Fortitude Check to Stabilize While Dying" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="710" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="resolve-checks/recover-from-conditions/stabilize-dying-ally-with-treatment-check" value="Stabilize Dying Ally with Treatment Check" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="770" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="translate-rank-to-measure" value="Translate Rank to Measure" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=11;" vertex="1" parent="1"><mxGeometry x="840" y="120" width="130" height="60" as="geometry" /></mxCell><mxCell id="translate-rank-to-measure/translate-rank-to-measure" value="Translate Rank to Measure" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="845" y="195" width="120" height="60" as="geometry" /></mxCell><mxCell id="translate-rank-to-measure/translate-rank-to-measure/translate-trait-rank-to-real-world-value" value="Translate Trait Rank to Real-World Value" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="850" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="translate-rank-to-measure/translate-rank-to-measure/derive-measurement-from-rank-formula" value="Derive Measurement from Rank Formula" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="910" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero" value="Construct Hero" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=11;" vertex="1" parent="1"><mxGeometry x="980" y="120" width="8380" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources" value="Allocate Resources" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="985" y="195" width="2080" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/set-series-power-level" value="Set Series Power Level" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="990" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/set-series-power-level/ac-0" value="**WHEN** the GM selects a *Series Power Level* (typically PL 10) **THEN** the system establishes that PL as the cap for all *Player Characters* in the series **AND** the *Starting PP Budget* is derived as PL × 15 **BUT** individual heroes cannot negotiate a different PL for themselves **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Power Level&quot; section, lines 1650–1767" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="990" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/set-series-power-level/ac-1" value="**WHEN** the *Series* PL is set **THEN** every *Paired Trait Cap* defaults to 2 × PL (attack/effect, Dodge/Toughness, Parry/Toughness, Fortitude/Will) or PL+10 (skill modifier) **Evidence:** `HeroesHandbook-rules__chunk_026.md` — PL limits section, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="990" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/set-series-power-level/ac-2" value="**WHEN** the GM sets PL to a non-default value (e.g., PL 8 or PL 12) **THEN** the system maps the chosen PL to the correct starting PP from the *Starting Power Points* table **AND** all five *Paired Trait Caps* recalculate for the new PL **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table, lines 1768–1807; `chunk_026.md` — PL 8 and PL 12 descriptions" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="990" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/set-series-power-level/ac-3" value="**WHEN** a player asks about *NPC Effective PL* **THEN** the GM derives the NPC's PL from their highest appropriate offensive/defensive pair **AND** no PP accounting is required for the NPC **BUT** the NPC is not constrained by the series *Paired Trait Caps* **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Power Level &amp; Non-player Characters&quot;, lines 1857–1902" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="990" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/set-series-power-level/ac-4" value="**WHEN** no *Series Power Level* has been established **THEN** the system blocks all hero construction steps **AND** shows a prompt to the GM to set the series PL before design proceeds **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Power Level&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="990" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/derive-starting-power-points-from-power-level" value="Derive Starting Power Points from Power Level" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="1250" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/derive-starting-power-points-from-power-level/ac-0" value="**WHEN** the series PL is established **THEN** the system calculates *Starting PP* as PL × 15 **AND** presents the result as the hero's design budget **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Starting Power Points&quot; section, lines 1650–1767" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1250" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/derive-starting-power-points-from-power-level/ac-1" value="**WHEN** the starting PP is derived **THEN** the system confirms the result matches the *Starting Power Points Table* entry for that PL **AND** shows the player the budget (e.g., PL 10 → 150 PP, PL 8 → 120 PP) **Evidence:** `HeroesHandbook-rules__chunk_024.md` — Starting Power Points table" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1250" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/derive-starting-power-points-from-power-level/ac-2" value="**WHEN** the GM applies a *GM Adjustment* to vary starting PP **THEN** the system uses the GM-specified value instead of the table default **AND** the player's design budget reflects the adjusted figure **BUT** the PL itself does not change — only the starting PP total is adjusted **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Starting Power Points&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1250" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/derive-starting-power-points-from-power-level/ac-3" value="**WHEN** the player begins hero design **THEN** the *Starting PP* value is locked before any trait allocation begins **AND** the system shows the budget prominently throughout the design process **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Spending Power Points&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1250" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-ability-ranks" value="Spend Power Points on Ability Ranks" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="1510" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-ability-ranks/ac-0" value="**WHEN** the *Player* assigns a rank to an ability (STR, STA, AGL, DEX, FGT, INT, AWE, or PRE) **THEN** the system charges *2 PP per Rank* **AND** deducts that cost from the *Remaining PP Budget* **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table, lines 1768–1807" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1510" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-ability-ranks/ac-1" value="**WHEN** the *Player* sets an ability rank of 0 **THEN** no PP are spent for that ability **AND** the ability contributes its rank-0 value to derived stats and untrained skill checks **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1510" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-ability-ranks/ac-2" value="**WHEN** an ability rank is set **THEN** the system evaluates the *Skill Modifier Limit* (PL+10) for every skill keyed to that ability **AND** flags any ability rank that alone would cause an untrained modifier to exceed PL+10 **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1510" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-ability-ranks/ac-3" value="**WHEN** the *Player* reviews the eight abilities **THEN** the system displays each ability's current rank, its 2 PP/rank cost, and the total ability PP outlay **AND** shows the *Remaining PP Budget* after all ability allocations **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1510" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-ability-ranks/ac-4" value="**WHEN** ability allocations are confirmed **THEN** the system locks those ranks into the *Remaining PP Budget* calculation **AND** the *Player* proceeds to defense, skill, advantage, and power allocation **BUT** spent PP cannot be redistributed to other traits without GM permission **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Spending Power Points&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1510" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-defense-ranks" value="Spend Power Points on Defense Ranks" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="1770" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-defense-ranks/ac-0" value="**WHEN** the *Player* purchases a defense rank (Dodge, Parry, Fortitude, or Will) **THEN** the system charges *1 PP per Rank* above the ability-provided base **AND** deducts the cost from the *Remaining PP Budget* **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table, lines 1768–1807" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1770" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-defense-ranks/ac-1" value="**WHEN** the *Player* increases *Toughness* **THEN** the system simultaneously checks both the Dodge/*Toughness* pair and the Parry/*Toughness* pair against 2 × PL **AND** flags a *Defense Pair Cap* violation if either sum would exceed the ceiling **Evidence:** `HeroesHandbook-rules__chunk_026.md` — Dodge &amp; Toughness and Parry &amp; Toughness limits" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1770" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-defense-ranks/ac-2" value="**WHEN** a *Defense Pair Cap* is reached **THEN** the system prevents further rank increases in the constrained defense **AND** shows the current pair sum and the 2 × PL ceiling **BUT** the *Player* may redistribute within the pair via a trade-off **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section, lines 1857–1902" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1770" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-defense-ranks/ac-3" value="**WHEN** the *Player* sets Fortitude and Will **THEN** the system validates Fortitude+Will against 2 × PL **AND** flags the Fortitude/Will pair if the sum would exceed the cap **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Fortitude &amp; Will&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1770" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-defense-ranks/ac-4" value="**WHEN** all four active and resistance defenses are allocated **THEN** the system confirms each *Defense Pair Cap* is satisfied **AND** shows the headroom remaining in each pair for advancement planning **Evidence:** `HeroesHandbook-rules__chunk_026.md` — PL limits section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="1770" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-skill-ranks" value="Spend Power Points on Skill Ranks" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="2030" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-skill-ranks/ac-0" value="**WHEN** the *Player* purchases *Skill Ranks* **THEN** the system charges *1 PP per 2 Ranks* (rounded down for odd totals) **AND** deducts the cost from the *Remaining PP Budget* **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table, lines 1768–1807" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2030" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-skill-ranks/ac-1" value="**WHEN** skill ranks are assigned **THEN** the system calculates the *Skill Modifier* (ability rank + skill ranks + advantage modifiers) for each affected skill **AND** validates it against the *Skill Modifier Limit* (PL+10) **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2030" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-skill-ranks/ac-2" value="**WHEN** a skill modifier would exceed PL+10 **THEN** the system blocks the rank purchase **AND** shows the current modifier breakdown so the *Player* can adjust **BUT** does not automatically select which component to reduce **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2030" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-skill-ranks/ac-3" value="**WHEN** skill ranks produce an odd total **THEN** the system rounds down for PP cost calculation **AND** shows the effective cost to the *Player* before they confirm **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs (1 PP per 2 skill ranks)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2030" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-skill-ranks/ac-4" value="**WHEN** the *Player* reviews all 24 skills **THEN** the system displays each skill's modifier, the PL+10 cap, and remaining headroom **AND** distinguishes trained skills (with purchased ranks) from untrained skills (ability rank only) **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2030" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-advantages" value="Spend Power Points on Advantages" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="2290" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-advantages/ac-0" value="**WHEN** the *Player* selects a flat (non-ranked) advantage **THEN** the system charges 1 PP per advantage **AND** deducts the cost from the *Remaining PP Budget* **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table, lines 1768–1807" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2290" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-advantages/ac-1" value="**WHEN** the *Player* selects a *Ranked Advantage* **THEN** the system charges 1 PP per rank **AND** records the advantage name and rank against the hero's advantage list **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2290" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-advantages/ac-2" value="**WHEN** an advantage provides a *Skill Modifier Bonus* **THEN** the system adds the bonus to the relevant skill modifier total **AND** checks the updated modifier against the PL+10 *Skill Modifier Limit* **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2290" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-advantages/ac-3" value="**WHEN** the *Player* encounters advantages listed in italics on an archetype sheet **THEN** the system marks those as *Enhanced Advantages* sourced from power effects **AND** charges them at their power cost rather than 1 PP per rank **Evidence:** `HeroesHandbook-rules__chunk_022.md` — Hero Archetypes section, lines 1556–1606" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2290" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-advantages/ac-4" value="**WHEN** the advantage list is confirmed **THEN** the system shows each advantage's PP cost, current rank, and any *Skill Modifier Bonus* **AND** includes all advantage costs in the running *Remaining PP Budget* calculation **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2290" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-powers" value="Spend Power Points on Powers" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="2550" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-powers/ac-0" value="**WHEN** the *Player* configures a *Power Effect* **THEN** the system calculates cost using the *Power Cost Formula* **AND** deducts the result from the *Remaining PP Budget* **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table (power formula), lines 1768–1807" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2550" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-powers/ac-1" value="**WHEN** the configured power includes an attack roll **THEN** the system validates attack bonus + effect rank against 2 × PL (*Attack &amp; Effect Cap*) **AND** flags a violation before the PP are committed **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Attack &amp; Effect&quot; limit, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2550" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-powers/ac-2" value="**WHEN** a power allows a resistance check without requiring an attack roll **THEN** the system validates effect rank alone against PL (not 2 × PL) **AND** blocks the configuration if effect rank exceeds PL **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Attack &amp; Effect&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2550" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-powers/ac-3" value="**WHEN** *Extras* are added to a power **THEN** the cost per rank increases by the extras' combined modifier **AND** the system recalculates the total cost at the updated per-rank rate **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table (power formula)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2550" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-powers/ac-4" value="**WHEN** *Flaws* are applied to a power **THEN** the cost per rank decreases by the flaws' combined modifier **AND** the system prevents the effective cost from dropping below 1 PP per rank **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table (power formula)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2550" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/spend-power-points-on-powers/ac-5" value="**WHEN** the *Player* finalizes a power **THEN** the system shows the full formula breakdown (base cost, extras, flaws, rank multiplier, flat modifiers) **AND** confirms the updated *Remaining PP Budget* **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2550" y="830" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/validate-power-points-total-balance" value="Validate Power Points Total Balance" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="2810" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/validate-power-points-total-balance/ac-0" value="**WHEN** the *Player* marks hero construction complete **THEN** the system sums all trait costs across abilities, defenses, skills, advantages, and powers **AND** compares the total to the *Starting PP* **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot; and &quot;Spending Power Points&quot; sections" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2810" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/validate-power-points-total-balance/ac-1" value="**WHEN** spent PP equals *Starting PP* exactly **THEN** the system confirms the hero is balanced **AND** enables the hero to proceed to GM review **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2810" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/validate-power-points-total-balance/ac-2" value="**WHEN** spent PP is less than *Starting PP* **THEN** the system shows the unspent amount **AND** blocks hero completion until the gap is resolved **BUT** does not automatically allocate the remaining points **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Spending Power Points&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2810" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/validate-power-points-total-balance/ac-3" value="**WHEN** spent PP exceeds *Starting PP* **THEN** the system shows the overage as a *Design Error* **AND** blocks completion until the *Player* reduces traits to bring the total within budget **BUT** does not select which traits to reduce **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Spending Power Points&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2810" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/allocate-resources/validate-power-points-total-balance/ac-4" value="**WHEN** the *Player* requests a cost breakdown **THEN** the system shows *Per-Category Totals* (abilities, defenses, skills, advantages, powers) **AND** the running sum versus starting PP **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;Spending Power Points&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="2810" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits" value="Enforce Power Level Limits" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="3075" y="195" width="1560" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-attack-and-effect-cap" value="Enforce Attack and Effect Cap" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="3080" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-attack-and-effect-cap/ac-0" value="**WHEN** the system evaluates an attack configuration **THEN** it computes *Attack Bonus* + *Effect Rank* **AND** rejects the configuration if the sum exceeds 2 × series PL **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Attack &amp; Effect&quot; limit, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3080" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-attack-and-effect-cap/ac-1" value="**WHEN** a power allows a resistance check but requires no attack roll **THEN** the system validates *Effect Rank* alone against PL **AND** blocks configurations where *Effect Rank* exceeds PL **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Attack &amp; Effect&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3080" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-attack-and-effect-cap/ac-2" value="**WHEN** a hero has multiple attacks **THEN** the system validates each attack/effect pair independently **AND** flags each pair that violates the cap individually **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Attack &amp; Effect&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3080" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-attack-and-effect-cap/ac-3" value="**WHEN** a *Violation Flag* is raised **THEN** the system shows the current sum and the 2 × PL ceiling **AND** lists options (lower *Attack Bonus*, reduce *Effect Rank*) **BUT** does not make the adjustment automatically **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3080" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-attack-and-effect-cap/ac-4" value="**WHEN** an attack is within cap after adjustment **THEN** the system clears the *Violation Flag* **AND** re-validates if *Attack Bonus* or *Effect Rank* is subsequently changed **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Attack &amp; Effect&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3080" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-dodge-and-toughness-cap" value="Enforce Dodge and Toughness Cap" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="3340" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-dodge-and-toughness-cap/ac-0" value="**WHEN** the *Player* sets *Dodge* or *Toughness* **THEN** the system computes *Dodge* + *Toughness* **AND** rejects any value that would push the sum above 2 × series PL **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Dodge &amp; Toughness&quot; limit, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3340" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-dodge-and-toughness-cap/ac-1" value="**WHEN** the *Player* increases *Toughness* **THEN** the system simultaneously re-evaluates the Dodge/*Toughness* pair and the Parry/*Toughness* pair **AND** flags both pairs if either sum would violate its cap **Evidence:** `HeroesHandbook-rules__chunk_026.md` — Dodge/Toughness and Parry/Toughness limits" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3340" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-dodge-and-toughness-cap/ac-2" value="**WHEN** the *Dodge &amp; Toughness Cap* is reached **THEN** the system prevents further increases to either defense **AND** shows the pair sum and the 2 × PL ceiling **BUT** a *Trade-Off* within the pair remains permitted **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3340" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-dodge-and-toughness-cap/ac-3" value="**WHEN** the *Player* lowers *Toughness* to create headroom **THEN** the system re-evaluates both the Dodge/*Toughness* and Parry/*Toughness* pairs **AND** updates the violation flags for each **Evidence:** `HeroesHandbook-rules__chunk_026.md` — Dodge/Toughness and Parry/Toughness limits" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3340" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-dodge-and-toughness-cap/ac-4" value="**WHEN** the pair is within cap after adjustment **THEN** the system confirms compliance and shows the remaining headroom **AND** continues to re-validate whenever *Dodge* or *Toughness* changes **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Dodge &amp; Toughness&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3340" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-parry-and-toughness-cap" value="Enforce Parry and Toughness Cap" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="3600" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-parry-and-toughness-cap/ac-0" value="**WHEN** the *Player* sets *Parry* or *Toughness* **THEN** the system computes *Parry* + *Toughness* **AND** rejects any value that would push the sum above 2 × series PL **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Parry &amp; Toughness&quot; limit, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3600" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-parry-and-toughness-cap/ac-1" value="**WHEN** *Toughness* changes **THEN** the system re-evaluates both the *Parry &amp; Toughness* pair and the *Dodge &amp; Toughness* pair **AND** applies the cap validation to both because of *Shared Toughness* **Evidence:** `HeroesHandbook-rules__chunk_026.md` — Parry/Toughness and Dodge/Toughness limits" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3600" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-parry-and-toughness-cap/ac-2" value="**WHEN** a *Parry &amp; Toughness Cap* violation is detected **THEN** the system shows the pair sum and the 2 × PL ceiling **AND** offers the option to redistribute within the pair via trade-off **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3600" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-parry-and-toughness-cap/ac-3" value="**WHEN** *Parry* and *Toughness* reach the cap **THEN** the system blocks further increases to either unless the other is reduced **AND** trade-off asymmetry within the cap is permitted **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3600" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-parry-and-toughness-cap/ac-4" value="**WHEN** the *Player* resolves a violation **THEN** the system re-validates both *Toughness*-sharing pairs **AND** confirms compliance for each **Evidence:** `HeroesHandbook-rules__chunk_026.md` — Parry/Toughness and Dodge/Toughness limits" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3600" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-fortitude-and-will-cap" value="Enforce Fortitude and Will Cap" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="3860" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-fortitude-and-will-cap/ac-0" value="**WHEN** the *Player* sets *Fortitude* or *Will* **THEN** the system computes *Fortitude* + *Will* **AND** rejects any value that would push the sum above 2 × series PL **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Fortitude &amp; Will&quot; limit, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3860" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-fortitude-and-will-cap/ac-1" value="**WHEN** the *Fortitude &amp; Will* pair approaches the cap **THEN** the system shows the remaining headroom **AND** allows trade-off distribution within the pair **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3860" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-fortitude-and-will-cap/ac-2" value="**WHEN** a *Fortitude &amp; Will Cap* violation is detected **THEN** the system flags the pair and shows the current sum versus the 2 × PL ceiling **AND** the *Player* must reduce *Fortitude* or *Will* to comply **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Fortitude &amp; Will&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3860" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-fortitude-and-will-cap/ac-3" value="**WHEN** all five limit pairs are valid **THEN** the system shows a *Power Level* compliance summary **AND** confirms no cap is violated **BUT** continues to re-validate whenever any relevant trait changes **Evidence:** `HeroesHandbook-rules__chunk_026.md` — full PL limits section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3860" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-fortitude-and-will-cap/ac-4" value="**WHEN** the *Player* lowers *Fortitude* to create *Will* headroom **THEN** the system recalculates the pair sum **AND** confirms the updated pair is within the *Fortitude &amp; Will Cap* **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Fortitude &amp; Will&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="3860" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-skill-modifier-cap" value="Enforce Skill Modifier Cap" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="4120" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-skill-modifier-cap/ac-0" value="**WHEN** the *Player* sets ability ranks or purchases skill ranks **THEN** the system computes the *Total Skill Modifier* for each affected skill **AND** rejects configurations where any modifier would exceed PL+10 **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4120" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-skill-modifier-cap/ac-1" value="**WHEN** a skill is used as an *Untrained Check* (ability rank only) **THEN** the system still applies the PL+10 cap to that skill **AND** flags if the ability rank alone would exceed PL+10 for that skill **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4120" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-skill-modifier-cap/ac-2" value="**WHEN** an advantage provides an *Advantage Modifier* to a skill **THEN** the system includes it in the *Total Skill Modifier* check **AND** re-validates the affected skill against the PL+10 limit **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4120" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-skill-modifier-cap/ac-3" value="**WHEN** a *Skill Modifier Limit* violation is detected **THEN** the system identifies which skill is over-cap and by how much **AND** the *Player* must reduce ability rank, skill ranks, or the *Advantage Modifier* to comply **BUT** the system does not select which component to reduce **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4120" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/enforce-skill-modifier-cap/ac-4" value="**WHEN** all 24 skills are within cap **THEN** the system confirms skill modifier compliance **AND** re-evaluates any skill whenever its ability rank, skill ranks, or relevant advantage modifiers change **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Skill Modifier&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4120" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/apply-trade-off-within-limit-pair" value="Apply Trade-Off within Limit Pair" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="4380" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/apply-trade-off-within-limit-pair/ac-0" value="**WHEN** the *Player* applies a *Trade-Off* to a defense pair **THEN** the system allows one trait to be higher than the other **AND** validates only that their sum does not exceed the *Hard Cap* **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section, lines 1857–1902" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4380" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/apply-trade-off-within-limit-pair/ac-1" value="**WHEN** the *Trade-Off* creates a disparity greater than 50% between the two traits **THEN** the system flags the asymmetry for GM attention **AND** records the disparity in the approval summary **BUT** does not automatically block the configuration **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4380" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/apply-trade-off-within-limit-pair/ac-2" value="**WHEN** the *Player* applies a *Trade-Off* to the attack/effect pair **THEN** the system allows *Attack Bonus* to exceed *Effect Rank* or vice versa **AND** validates only that the sum does not exceed 2 × PL **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4380" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/apply-trade-off-within-limit-pair/ac-3" value="**WHEN** a trade-off is reviewed by the GM at approval **THEN** the GM evaluates whether the asymmetry is self-limiting **AND** may decline to approve extreme configurations (e.g., zero Dodge with maximum *Toughness*) **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4380" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/enforce-power-level-limits/apply-trade-off-within-limit-pair/ac-4" value="**WHEN** a *Trade-Off* is applied within any *Limit Pair* **THEN** the system shows both the individual trait values and the combined sum versus the *Hard Cap* **AND** confirms the pair remains within cap **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4380" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity" value="Define Hero Identity" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="4645" y="195" width="1300" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/develop-hero-concept" value="Develop Hero Concept" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="4650" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/develop-hero-concept/ac-0" value="**WHEN** the *Player* begins character design **THEN** the system prompts for a *Hero Concept* covering basic abilities, powers, origin, and theme **AND** saves the concept as the *Design Intent* before any PP is allocated **Evidence:** `HeroesHandbook-rules__chunk_023.md` — &quot;1. Hero Concept&quot; step, lines 1607–1649" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4650" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/develop-hero-concept/ac-1" value="**WHEN** the *Hero Concept* is saved **THEN** the *Player* is prompted to share it with the GM to validate series fit **AND** to consult fellow players for *Team Composition* review **Evidence:** `HeroesHandbook-rules__chunk_023.md` — &quot;2. Gamemaster Guidelines&quot; step" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4650" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/develop-hero-concept/ac-2" value="**WHEN** the *Player* needs inspiration **THEN** the system offers access to hero archetypes as reference examples **AND** notes that concepts can draw from archetypes, comics, TV, or movies **Evidence:** `HeroesHandbook-rules__chunk_022.md` — Chapter 2 introduction, lines 1556–1606" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4650" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/develop-hero-concept/ac-3" value="**WHEN** *GM Guidelines* restrict certain powers or origins **THEN** the system validates the *Hero Concept* against those constraints **AND** flags concept elements that violate GM restrictions before design proceeds **Evidence:** `HeroesHandbook-rules__chunk_023.md` — &quot;2. Gamemaster Guidelines&quot; step" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4650" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/develop-hero-concept/ac-4" value="**WHEN** the concept is confirmed **THEN** all subsequent trait allocations are grounded in the *Design Intent* **AND** the system carries the concept narrative forward to the approval step **Evidence:** `HeroesHandbook-rules__chunk_023.md` — Chapter 2 hero design steps" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4650" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/select-hero-archetype-as-starting-point" value="Select Hero Archetype as Starting Point" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="4910" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/select-hero-archetype-as-starting-point/ac-0" value="**WHEN** the *Player* selects a *Hero Archetype* **THEN** the system loads the complete PL 10 hero template **AND** pre-fills all trait allocations according to the archetype definition **Evidence:** `HeroesHandbook-rules__chunk_022.md` — &quot;Hero Archetypes&quot; section, lines 1556–1606" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4910" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/select-hero-archetype-as-starting-point/ac-1" value="**WHEN** an archetype has an *Options Section* **THEN** the system presents the available variant choices **AND** applies the *Player's* selections to the pre-filled template **Evidence:** `HeroesHandbook-rules__chunk_022.md` — &quot;Hero Archetypes&quot; Options section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4910" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/select-hero-archetype-as-starting-point/ac-2" value="**WHEN** the *Player* customizes beyond the *Options Section* **THEN** the system treats all archetype traits as mutable **AND** re-validates the design against PP budget, PL caps, and GM approval requirements **Evidence:** `HeroesHandbook-rules__chunk_022.md` — &quot;Hero Archetypes&quot; customization note" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4910" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/select-hero-archetype-as-starting-point/ac-3" value="**WHEN** an archetype lists advantages in italics **THEN** the system identifies them as *Enhanced Advantages* from power effects **AND** charges their cost against the powers line rather than the direct advantages line **Evidence:** `HeroesHandbook-rules__chunk_022.md` — Hero Archetypes italicized advantage note" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4910" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/select-hero-archetype-as-starting-point/ac-4" value="**WHEN** the *Player* skips archetype selection **THEN** the system proceeds to full hero design from scratch **AND** marks the archetype step as optional in the construction flow **Evidence:** `HeroesHandbook-rules__chunk_022.md` — Chapter 2 introduction" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="4910" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/choose-hero-origin" value="Choose Hero Origin" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="5170" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/choose-hero-origin/ac-0" value="**WHEN** the *Player* chooses an *Origin* **THEN** the system records the narrative provenance of the hero's powers **AND** applies the origin as a *Power Descriptor* to the hero's power set **Evidence:** `HeroesHandbook-rules__chunk_033.md` — &quot;Origins As Descriptors&quot;, lines 2186–2225" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5170" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/choose-hero-origin/ac-1" value="**WHEN** an *Origin* is recorded as a *Power Descriptor* **THEN** the system notes that powers with the matching descriptor can be detected or targeted by origin-sensitive effects **AND** the GM may use this in play (e.g., mutant-detection powers target mutant heroes) **Evidence:** `HeroesHandbook-rules__chunk_033.md` — &quot;Origins As Descriptors&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5170" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/choose-hero-origin/ac-2" value="**WHEN** the series setting has an *Origin Restriction* **THEN** the system enforces the GM's restriction **AND** prevents the *Player* from selecting a restricted origin type **Evidence:** `HeroesHandbook-rules__chunk_033.md` — &quot;Origin Guidelines&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5170" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/choose-hero-origin/ac-3" value="**WHEN** the *Player* selects a Training origin **THEN** the system notes that the hero may have rivals or foes who trained alongside them **AND** prompts consideration of this as a source for *Enemy* or rivalry complications **Evidence:** `HeroesHandbook-rules__chunk_033.md` — &quot;Training&quot; origin description" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5170" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/choose-hero-origin/ac-4" value="**WHEN** the origin is confirmed **THEN** the *Power Descriptor* is saved with the hero's trait profile **AND** the origin narrative is linked to the hero's background record **Evidence:** `HeroesHandbook-rules__chunk_033.md` — &quot;Origins As Descriptors&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5170" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/record-hero-background-details" value="Record Hero Background Details" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="5430" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/record-hero-background-details/ac-0" value="**WHEN** the *Player* records a hero name **THEN** the system accepts any naming convention (origin-based, power-based, themed, titled, aesthetic, or real name) **AND** stores it as the hero's *Code Name* or public identity **Evidence:** `HeroesHandbook-rules__chunk_032.md` — &quot;Background&quot; name section, lines 2146–2185" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5430" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/record-hero-background-details/ac-1" value="**WHEN** the *Player* records the hero's *Age* **THEN** the system shows that older heroes trend toward higher skill ranks and lower raw physical abilities **AND** younger heroes may have emerging raw capability with fewer trained skills **Evidence:** `HeroesHandbook-rules__chunk_033.md` — &quot;Age&quot; section, lines 2186–2225" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5430" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/record-hero-background-details/ac-2" value="**WHEN** the *Player* records appearance and personality details **THEN** the system stores them as narrative *Background* **AND** links them to the *Hero Concept* for consistency **Evidence:** `HeroesHandbook-rules__chunk_032.md` — &quot;Background&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5430" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/record-hero-background-details/ac-3" value="**WHEN** the *Player* records *Goals* beyond generic heroism **THEN** the system saves them as potential sources for complications and GM story hooks **AND** notes their relationship to the hero's *Motivation* complication **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Goals&quot; section, lines 2226–2297" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5430" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/record-hero-background-details/ac-4" value="**WHEN** the *Player* specifies public vs secret identity in background **THEN** the system links the choice to the *Identity* complication **AND** notes which persona management approach the hero is taking **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Alternate Identity&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5430" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/design-hero-costume" value="Design Hero Costume" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="5690" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/design-hero-costume/ac-0" value="**WHEN** the *Player* designs a *Costume* **THEN** the system records the costume description as the hero's distinctive visual identity **AND** stores it as part of the hero's background record **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Costume&quot; section, lines 2226–2297" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5690" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/design-hero-costume/ac-1" value="**WHEN** the costume is described **THEN** the system applies the *Power Immunity Convention* automatically **AND** notes that this immunity costs no PP **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Costume&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5690" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/design-hero-costume/ac-2" value="**WHEN** the hero maintains a *Secret Identity* **THEN** the system notes that the *Costume* is the key *Secret Identity Transition* element **AND** links the costume to the hero's identity complication **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Alternate Identity&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5690" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/design-hero-costume/ac-3" value="**WHEN** the *Player* wants mechanical costume details (armor values, gadgets) **THEN** the system directs them to the *Equipment Module* (Gadgets &amp; Gear) **AND** does not apply mechanical stats to the costume within the Character module **BUT** the costume description is still recorded as background **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Costume&quot; section (&quot;For more on costumes as equipment&quot;)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5690" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/define-hero-identity/design-hero-costume/ac-4" value="**WHEN** the costume design is saved **THEN** the hero's public persona is fully defined **AND** the system confirms the costume is stored as part of the hero's background record **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Costume&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5690" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications" value="Choose Complications" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="5955" y="195" width="1300" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-motivation-complication" value="Choose Motivation Complication" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="5960" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-motivation-complication/ac-0" value="**WHEN** the *Player* chooses a *Motivation* **THEN** the system records the primary drive (Justice, Responsibility, Love, etc.) **AND** marks the *Required Complication* as satisfied **Evidence:** `HeroesHandbook-rules__chunk_028.md` — &quot;Motivation&quot; section, lines 1903–1957" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5960" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-motivation-complication/ac-1" value="**WHEN** the *Motivation* is recorded **THEN** the system explains how the GM will invoke it (when motivation creates genuine conflict, the player earns a hero point) **AND** notes that shared motivation may grant circumstance bonuses in social interaction at GM option **Evidence:** `HeroesHandbook-rules__chunk_029.md` — &quot;Motivation And Influence&quot; section, lines 1958–2052" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5960" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-motivation-complication/ac-2" value="**WHEN** the *Player* selects a *Power Descriptor (Motivation)* link at GM option **THEN** the system notes that the motivation can function as a descriptor for the hero's powers **AND** flags this as requiring GM approval **Evidence:** `HeroesHandbook-rules__chunk_029.md` — &quot;Motivations As Descriptors&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5960" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-motivation-complication/ac-3" value="**WHEN** no *Motivation* is selected **THEN** the system blocks hero completion **AND** shows the *Required Complication* message identifying motivation as the outstanding item **Evidence:** `HeroesHandbook-rules__chunk_028.md` — Motivation section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5960" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-motivation-complication/ac-4" value="**WHEN** the *Player* attempts to add a second Motivation **THEN** the system shows that each hero has exactly one Motivation **AND** prevents a second motivation from being added **BUT** additional motivational nuance can be expressed in the hero's *Goals* and background **Evidence:** `HeroesHandbook-rules__chunk_028.md` — Motivation section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="5960" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-complication" value="Choose Complication" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="6220" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-complication/ac-0" value="**WHEN** the *Player* chooses an *Enemy* complication **THEN** the system prompts for the adversary's identity and the nature of the enmity (one-sided or mutual) **AND** records that a *Hero Point* is earned when the GM introduces the enemy and specific harm results **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; section (Enemy), lines 1958–2052 (chunk_029)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6220" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-complication/ac-1" value="**WHEN** the *Player* chooses an *Identity* complication **THEN** the system records the choice of secret or public identity **AND** notes that dual-identity heroes must actively manage two separate personas **Evidence:** `HeroesHandbook-rules__chunk_028.md` — Complications list; `chunk_034.md` — &quot;Alternate Identity&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6220" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-complication/ac-2" value="**WHEN** the *Player* chooses a *Responsibility* complication **THEN** the system prompts for the obligation type (family, professional, civic) **AND** records that a *Hero Point* is earned when the responsibility is visibly neglected or in active conflict **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; (Responsibility)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6220" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-complication/ac-3" value="**WHEN** the *Player* chooses a *Relationship* complication **THEN** the system prompts for the key person's identity and whether they know the hero's secret **AND** records the corresponding risk (danger target if informed; deception burden if not) **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; (Relationship)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6220" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-complication/ac-4" value="**WHEN** the *Player* chooses a *Secret* complication **THEN** the system prompts for what is hidden and from whom **AND** records that a *Hero Point* is earned only when active threat of exposure occurs **BUT** the mere existence of the secret without an active threat does not earn a point **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; (Secret)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6220" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/choose-complication/ac-5" value="**WHEN** the *Player* chooses a *Power Loss* complication **THEN** the system prompts for the specific triggering circumstance **AND** records that a *Hero Point* is earned only when powers actually fail due to the trigger **BUT** proximity to the trigger without actual power failure does not earn a point **Evidence:** `HeroesHandbook-rules__chunk_028.md` — Complications section; `chunk_029.md` — &quot;Motivations As Origins&quot; (power loss link)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6220" y="830" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/specify-weakness-trigger-and-effect-with-gm" value="Specify Weakness Trigger and Effect with GM" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="6480" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/specify-weakness-trigger-and-effect-with-gm/ac-0" value="**WHEN** the *Player* specifies a *Weakness* complication **THEN** the system prompts for both the *Trigger Condition* AND the *Mechanical Effect* **AND** records both as required elements of the weakness definition **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; (Weakness)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6480" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/specify-weakness-trigger-and-effect-with-gm/ac-1" value="**WHEN** the *Trigger Condition* and *Mechanical Effect* are defined **THEN** the system marks the weakness as pending *GM Negotiation* **AND** shows that both must be agreed before hero approval is complete **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; (Weakness)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6480" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/specify-weakness-trigger-and-effect-with-gm/ac-2" value="**WHEN** the GM approves the weakness definition **THEN** the system stores the confirmed *Trigger Condition* and *Mechanical Effect* **AND** records that a hero point is earned when the GM uses the weakness as a complication in play **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; (Weakness)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6480" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/specify-weakness-trigger-and-effect-with-gm/ac-3" value="**WHEN** a *Trigger Condition* is specified without an agreed *Mechanical Effect* **THEN** the system flags the weakness as incomplete **AND** blocks hero completion until the effect is defined **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; (Weakness)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6480" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/specify-weakness-trigger-and-effect-with-gm/ac-4" value="**WHEN** the weakness is invoked in play **THEN** the system confirms a hero point is earned only when the weakness creates actual hardship **BUT** the hero point is not earned merely because the trigger is present without actual harm **Evidence:** `HeroesHandbook-rules__chunk_030.md` — &quot;Other Complications&quot; (Weakness)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6480" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/validate-minimum-complication-requirement" value="Validate Minimum Complication Requirement" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="6740" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/validate-minimum-complication-requirement/ac-0" value="**WHEN** the *Player* completes complication selection **THEN** the system checks that at least one *Motivation* is recorded **AND** confirms the *Minimum Complication Requirement* is met **Evidence:** `HeroesHandbook-rules__chunk_028.md` — &quot;Complications&quot; section, lines 1903–1957" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6740" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/validate-minimum-complication-requirement/ac-1" value="**WHEN** no *Motivation* is present **THEN** the system blocks hero completion with a clear message **AND** identifies the motivation as the outstanding required item **Evidence:** `HeroesHandbook-rules__chunk_028.md` — &quot;Motivation&quot; requirement" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6740" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/validate-minimum-complication-requirement/ac-2" value="**WHEN** only a *Motivation* is present with no other complications **THEN** the system notes that two or more total complications are strongly recommended **AND** shows the additional hero-point opportunities the hero would gain from further complications **BUT** does not block completion on this basis **Evidence:** `HeroesHandbook-rules__chunk_028.md` — &quot;Choosing Complications&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6740" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/validate-minimum-complication-requirement/ac-3" value="**WHEN** two or more complications are recorded **THEN** the system shows the full complication list **AND** confirms all *Complication Completeness* fields are specified (trigger conditions, narrative detail, any weakness effects) **Evidence:** `HeroesHandbook-rules__chunk_028.md` — &quot;Complications&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6740" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/validate-minimum-complication-requirement/ac-4" value="**WHEN** a complication definition is incomplete (missing trigger or effect) **THEN** the system blocks the transition to GM review **AND** shows which complication details are still missing **Evidence:** `HeroesHandbook-rules__chunk_028.md` — Complications section; `chunk_030.md` — Weakness entry" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="6740" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/evolve-complication-over-series" value="Evolve Complication over Series" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="7000" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/evolve-complication-over-series/ac-0" value="**WHEN** a series complication is resolved during play **THEN** the *Player* and GM can define a new complication to replace it **AND** the system records the updated *Active Complications* list **Evidence:** `HeroesHandbook-rules__chunk_031.md` — &quot;Changing Complications&quot; section, lines 2104–2145" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7000" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/evolve-complication-over-series/ac-1" value="**WHEN** the GM sets a *GM Complication Limit* **THEN** the system enforces the cap on active complications **AND** shows which complications are currently active versus resolved **Evidence:** `HeroesHandbook-rules__chunk_031.md` — &quot;Changing Complications&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7000" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/evolve-complication-over-series/ac-2" value="**WHEN** a complication evolves (rivalry resolved, new relationship begins) **THEN** the system records the change **AND** preserves the narrative history of the old complication for series continuity **Evidence:** `HeroesHandbook-rules__chunk_031.md` — &quot;Changing Complications&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7000" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/evolve-complication-over-series/ac-3" value="**WHEN** an injury or persistent in-play setback arises **THEN** the system can record it as a *Temporary Complication* **AND** makes it available for the GM to invoke for hero point rewards until resolved **Evidence:** `HeroesHandbook-rules__chunk_031.md` — &quot;Complications And Injuries&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7000" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/choose-complications/evolve-complication-over-series/ac-4" value="**WHEN** the *Player* proposes evolving a complication **THEN** the system prompts for GM confirmation **AND** marks the evolution as pending until the GM approves **BUT** the hero's existing complications remain active until the evolution is confirmed **Evidence:** `HeroesHandbook-rules__chunk_031.md` — &quot;Changing Complications&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7000" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero" value="Approve and Finalize Hero" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="7265" y="195" width="780" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/review-hero-power-points-allocation" value="Review Hero Power Points Allocation" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="7270" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/review-hero-power-points-allocation/ac-0" value="**WHEN** the GM reviews a hero's PP allocation **THEN** the system presents *Per-Category Totals* (abilities, defenses, skills, advantages, powers) **AND** the sum compared to *Starting PP* **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot; section, lines 1650–1767" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7270" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/review-hero-power-points-allocation/ac-1" value="**WHEN** the PP sum does not equal *Starting PP* **THEN** the system flags the discrepancy **AND** the GM withholds approval until the *Player* corrects it **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7270" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/review-hero-power-points-allocation/ac-2" value="**WHEN** the GM checks *Allocation Correctness* **THEN** the system confirms each trait cost uses the correct rate from *Basic Trait Costs* **AND** highlights any unusual cost structures (powers with many extras or flaws) for GM attention **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7270" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/review-hero-power-points-allocation/ac-3" value="**WHEN** the PP allocation is verified as balanced **THEN** the GM marks this review step complete **AND** the hero advances to the PL guidelines verification **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7270" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/review-hero-power-points-allocation/ac-4" value="**WHEN** the GM requests a specific trait's cost justification **THEN** the system shows the formula detail for that trait **AND** the GM can examine individual power cost breakdowns for verification **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs table (power formula)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7270" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/verify-hero-follows-power-level-guidelines" value="Verify Hero Follows Power Level Guidelines" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="7530" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/verify-hero-follows-power-level-guidelines/ac-0" value="**WHEN** the GM verifies *PL Guidelines* **THEN** the system shows the *Limit Pair Status* for all five pairs (Attack/Effect, Dodge/Toughness, Parry/Toughness, Fortitude/Will, Skill Modifier) **AND** confirms all pairs are within their caps **Evidence:** `HeroesHandbook-rules__chunk_026.md` — full PL limits section, lines 1808–1856" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7530" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/verify-hero-follows-power-level-guidelines/ac-1" value="**WHEN** the GM checks for *Extreme Trade-Offs* **THEN** the system highlights any pair where one trait exceeds the other by more than 50% **AND** the GM evaluates whether to approve the asymmetry **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Trade-offs&quot; section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7530" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/verify-hero-follows-power-level-guidelines/ac-2" value="**WHEN** the series has *Series-Specific Guidelines* **THEN** the GM verifies the hero's origin, powers, and background against those constraints **AND** notes any deviations from the series requirements **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot; (series guidelines reference)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7530" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/verify-hero-follows-power-level-guidelines/ac-3" value="**WHEN** all *PL Guidelines* are met **THEN** the system marks PL verification complete **AND** the hero advances to final GM approval **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7530" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/verify-hero-follows-power-level-guidelines/ac-4" value="**WHEN** a *PL Guideline* violation is found **THEN** the system identifies which pair or guideline is violated **AND** the *Player* must correct the issue before the hero can be approved **BUT** the GM does not make corrections on the player's behalf **Evidence:** `HeroesHandbook-rules__chunk_026.md` — PL limits section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7530" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/approve-completed-hero-for-play" value="Approve Completed Hero for Play" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="7790" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/approve-completed-hero-for-play/ac-0" value="**WHEN** PP allocation and PL guidelines are both verified **THEN** the GM performs a final holistic review for *Series Fit* **AND** confirms the hero is complete, consistent, and suited to the overall game **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot; section, lines 1650–1767" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7790" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/approve-completed-hero-for-play/ac-1" value="**WHEN** the GM approves the hero **THEN** the system marks the hero as *Ready for Play* **AND** the hero is unlocked for use in the first session **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7790" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/approve-completed-hero-for-play/ac-2" value="**WHEN** the GM identifies a *Series Fit* concern not captured by mechanical checks **THEN** the GM may request adjustments to background, concept, or complication definitions **AND** the *GM Approval* is held pending those changes **BUT** mechanical validation alone does not guarantee series fit approval **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot; (series fit language)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7790" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/approve-completed-hero-for-play/ac-3" value="**WHEN** the hero is approved **THEN** the system produces a *Final Character Summary* confirming PP balance, PL compliance, complication list, and identity details **AND** the hero record is locked for play **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7790" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/approve-and-finalize-hero/approve-completed-hero-for-play/ac-4" value="**WHEN** the *Player* resubmits after GM-requested changes **THEN** the system re-runs PP balance and PL cap validation **AND** presents the updated hero for GM re-review **Evidence:** `HeroesHandbook-rules__chunk_024.md` — &quot;10. Gamemaster Approval&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="7790" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero" value="Advance Hero" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="8055" y="195" width="1300" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/award-power-points-after-adventure" value="Award Power Points after Adventure" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="8060" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/award-power-points-after-adventure/ac-0" value="**WHEN** heroes complete a single-session adventure **THEN** the GM awards 1 *PP Award* to each participating hero **AND** the system records the award against each hero's advancement log **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot; section, lines 2226–2297" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8060" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/award-power-points-after-adventure/ac-1" value="**WHEN** the adventure involved especially powerful foes or difficult challenges **THEN** the GM may award 2 PP instead of 1 (*Bonus PP*) **AND** the system records the reason for the increased award **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8060" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/award-power-points-after-adventure/ac-2" value="**WHEN** an adventure spans multiple sessions **THEN** the GM awards 1 PP per session **AND** optionally grants a *Bonus PP* at the end of the arc for exceptional performance **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8060" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/award-power-points-after-adventure/ac-3" value="**WHEN** heroes handle an adventure especially poorly **THEN** the GM may choose not to award any PP **AND** the system records the withheld award with the stated reason **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8060" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/award-power-points-after-adventure/ac-4" value="**WHEN** the *PP Award* is recorded **THEN** the system adds it to each hero's unspent PP pool **AND** shows the cumulative total of unspent earned PP available for spending **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8060" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/spend-earned-power-points-on-traits" value="Spend Earned Power Points on Traits" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="8320" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/spend-earned-power-points-on-traits/ac-0" value="**WHEN** the *Player* spends *Earned PP* on a new or improved trait **THEN** the system applies the same cost rates as construction (2 PP/ability rank, 1 PP/defense rank, etc.) **AND** deducts the cost from the *Unspent PP Pool* **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot;, lines 2226–2297" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8320" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/spend-earned-power-points-on-traits/ac-1" value="**WHEN** the *Player* wants to improve a trait that is at the PL cap **THEN** the system blocks the improvement **AND** shows the cap constraint and the option to save PP for after the next PL increase **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8320" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/spend-earned-power-points-on-traits/ac-2" value="**WHEN** the *Player* spends *Earned PP* **THEN** the system validates all affected limit pairs against the current PL caps **AND** flags any violations that would result from the new allocation **Evidence:** `HeroesHandbook-rules__chunk_026.md` — PL limits section (apply equally to advancement)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8320" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/spend-earned-power-points-on-traits/ac-3" value="**WHEN** the *Player* improves a power's rank or adds extras **THEN** the system recalculates the power cost at the updated formula **AND** deducts the incremental cost difference from the *Unspent PP Pool* **Evidence:** `HeroesHandbook-rules__chunk_025.md` — Basic Trait Costs (power formula)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8320" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/spend-earned-power-points-on-traits/ac-4" value="**WHEN** *Earned PP* are spent **THEN** they become locked to the chosen trait just as construction PP are **AND** the same reallocation rules apply **BUT** spending is only valid *Between Sessions*, not during active play **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8320" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/enforce-power-level-limits-on-earned-spending" value="Enforce Power Level Limits on Earned Spending" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="8580" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/enforce-power-level-limits-on-earned-spending/ac-0" value="**WHEN** the *Player* spends *Earned PP* on any trait **THEN** the system re-validates all affected limit pairs **AND** blocks the improvement if it would violate any cap **Evidence:** `HeroesHandbook-rules__chunk_026.md` — PL limits section; `chunk_034.md` — advancement section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8580" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/enforce-power-level-limits-on-earned-spending/ac-1" value="**WHEN** an improvement to *Toughness* is proposed **THEN** the system checks both the Dodge/*Toughness* and Parry/*Toughness* pairs **AND** shows the available *Cap Headroom* before the *Player* commits the PP **Evidence:** `HeroesHandbook-rules__chunk_026.md` — Dodge/Toughness and Parry/Toughness limits" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8580" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/enforce-power-level-limits-on-earned-spending/ac-2" value="**WHEN** an improvement to an attack's effect rank is proposed **THEN** the system checks the attack/effect pair against 2 × PL **AND** blocks the rank increase if it would push the pair over the cap **Evidence:** `HeroesHandbook-rules__chunk_026.md` — &quot;Attack &amp; Effect&quot; limit" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8580" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/enforce-power-level-limits-on-earned-spending/ac-3" value="**WHEN** a cap is at maximum headroom used and the *Player* still has unspent PP **THEN** the system shows the *Player* can save those PP for after the next PL increase **AND** the PP remain in the *Unspent PP Pool* **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Hero Advancement &amp; Improvement&quot; (saving for PL increase)" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8580" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/enforce-power-level-limits-on-earned-spending/ac-4" value="**WHEN** all proposed improvements are within cap **THEN** the system confirms the expenditure **AND** updates the hero's trait values and remaining *Unspent PP Pool* count **Evidence:** `HeroesHandbook-rules__chunk_026.md` — PL limits; `chunk_034.md` — advancement section" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8580" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/raise-series-power-level" value="Raise Series Power Level" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="8840" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/raise-series-power-level/ac-0" value="**WHEN** heroes have accumulated approximately 15 PP since the last *Series PL Increase* **THEN** the GM raises the series PL by +1 **AND** the system recalculates all five limit pair caps to the new PL values **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Increasing Power Level&quot; section, lines 2226–2297" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8840" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/raise-series-power-level/ac-1" value="**WHEN** the series PL increases **THEN** all heroes can now spend accumulated PP on *Previously-Capped Traits* **AND** the system lifts the cap blocks for those traits **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Increasing Power Level&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8840" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/raise-series-power-level/ac-2" value="**WHEN** the series PL increases **THEN** the GM performs *NPC Re-evaluation* for key villain antagonists **AND** may improve some villains' traits while intentionally leaving others behind as heroes outgrow them **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Increasing Power Level&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8840" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/raise-series-power-level/ac-3" value="**WHEN** the system updates caps after a *Series PL Increase* **THEN** it re-validates all heroes' existing traits against the new limits **AND** confirms no violations (a PL increase always expands headroom, never reduces it) **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Increasing Power Level&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8840" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/raise-series-power-level/ac-4" value="**WHEN** the *Series PL Increase* is recorded **THEN** new villains and challenges calibrated to the new PL can be introduced **AND** the system notes the new reference point (new PL × 15 PP) for the next increase trigger **Evidence:** `HeroesHandbook-rules__chunk_034.md` — &quot;Increasing Power Level&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="8840" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/reallocate-power-points-via-transformation" value="Reallocate Power Points via Transformation" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9100" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/reallocate-power-points-via-transformation/ac-0" value="**WHEN** a hero suffers a *Transformed Condition* (intense radiation, mutagenic chemicals, cosmic power source) **THEN** the GM may allow the *Player* to reallocate spent PP from one trait to another **AND** the system processes the *Reallocation* within current PL limits **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Reallocating Power Points&quot; section, lines 1857–1902" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="9100" y="480" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/reallocate-power-points-via-transformation/ac-1" value="**WHEN** the GM permits *Reallocation* as a deliberate narrative event **THEN** the system validates the new *Trait Profile Change* against all five limit pairs **AND** applies the changes if the updated profile is within cap **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Reallocating Power Points&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="9100" y="550" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/reallocate-power-points-via-transformation/ac-2" value="**WHEN** reallocation results in the hero losing a trait entirely **THEN** the system removes the trait and its cost from the profile **AND** adds the freed PP to the available pool for reallocation **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Reallocating Power Points&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="9100" y="620" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/reallocate-power-points-via-transformation/ac-3" value="**WHEN** reallocation is triggered by a *Temporary Reallocation* condition **THEN** the system marks the trait changes as temporary **AND** tracks the hero's original profile for restoration when the condition ends **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Reallocating Power Points&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="9100" y="690" width="250" height="60" as="geometry" /></mxCell><mxCell id="construct-hero/advance-hero/reallocate-power-points-via-transformation/ac-4" value="**WHEN** reallocation is completed **THEN** the system confirms the revised profile satisfies all PL limits **AND** the revised PP allocation is locked until the next *Transformed Condition* or GM-permitted change **BUT** normal between-session spending rules do not allow reallocation without a triggering event **Evidence:** `HeroesHandbook-rules__chunk_027.md` — &quot;Reallocating Power Points&quot;" style="whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;align=left;" vertex="1" parent="1"><mxGeometry x="9100" y="760" width="250" height="60" as="geometry" /></mxCell><mxCell id="assign-abilities" value="Assign Abilities" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#000000;fontSize=11;" vertex="1" parent="1"><mxGeometry x="9370" y="120" width="880" height="60" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-ability-scores" value="Configure Ability Scores" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="9375" y="195" width="240" height="60" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-ability-scores/set-ability-rank" value="Set Ability Rank" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9380" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-ability-scores/designate-ability-rank-portion-as-enhanced" value="Designate Ability Rank Portion as Enhanced" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9440" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-ability-scores/cascade-trait-changes-on-ability-rank-alteration" value="Cascade Trait Changes on Ability Rank Alteration" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9500" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-ability-scores/enforce-ability-rank-ceiling-per-power-level" value="Enforce Ability Rank Ceiling per Power Level" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9560" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-derived-defenses" value="Configure Derived Defenses" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="9625" y="195" width="240" height="60" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-derived-defenses/derive-base-defense-rank-from-ability" value="Derive Base Defense Rank from Ability" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9630" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-derived-defenses/increase-defense-rank-above-ability-base" value="Increase Defense Rank Above Ability Base" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9690" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-derived-defenses/enforce-toughness-increase-restriction" value="Enforce Toughness Increase Restriction" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9750" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/configure-derived-defenses/derive-initiative-modifier-from-agility" value="Derive Initiative Modifier from Agility" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9810" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/handle-absent-ability" value="Handle Absent Ability" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#000000;fontSize=10;" vertex="1" parent="1"><mxGeometry x="9875" y="195" width="180" height="60" as="geometry" /></mxCell><mxCell id="assign-abilities/handle-absent-ability/apply-absent-ability-capability-restrictions" value="Apply Absent Ability Capability Restrictions" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9880" y="420" width="50" height="50" as="geometry" /></mxCell><mxCell id="assign-abilities/handle-absent-ability/grant-bonus-power-points-for-absent-ability" value="Grant Bonus Power Points for Absent Ability" style="whiteSpace=wrap;html=1;overflow=hidden;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#000000;fontSize=8;" vertex="1" parent="1"><mxGeometry x="9940" y="420" width=